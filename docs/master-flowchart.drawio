        <mxCell id="legNote" value="Full detail:&lt;br&gt;docs/hooks.md&lt;br&gt;docs/orchestration.md&lt;br&gt;docs/parallel-isolation.md&lt;br&gt;docs/workflows.md&lt;br&gt;docs/speckit.md" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
