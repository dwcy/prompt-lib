        <mxCell id="mcpPanelTitle" value="MCP servers (external, all local)" style="text;html=1;fontSize=13;fontStyle=1;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1360" y="530" width="280" height="24" as="geometry" />
        </mxCell>
        <mxCell id="mcpPanel" value="Callable from any step above; they don't&lt;br&gt;add execution contexts to the chain:&lt;br&gt;&lt;br&gt;• mcp-bus — this repo, services/mcp-bus,&lt;br&gt;&amp;nbsp;&amp;nbsp;local SQLite. Inter-agent bus + shared&lt;br&gt;&amp;nbsp;&amp;nbsp;memory + registry. Used in Lane C above.&lt;br&gt;• context7 — live library/framework docs&lt;br&gt;• microsoft-docs — Azure / MS Learn docs&lt;br&gt;• claude-in-chrome, playwright — browser&lt;br&gt;• Slack, Vercel, Azure — team/cloud plugins&lt;br&gt;&lt;br&gt;Full registration: global/MCP.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f5ff;strokeColor=#6699cc;fontSize=11;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1360" y="560" width="280" height="230" as="geometry" />
        </mxCell>

        <!-- Edges: every edge has explicit exit/entry points so drawio's auto-router -->
        <!-- never has to guess a path through unrelated nodes. -->
