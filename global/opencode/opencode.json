{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codex": {
      "type": "local",
      "command": [
        "codex",
        "mcp-server"
      ],
      "enabled": true
    }
  },
  "permission": {
    "codex_*": "ask",
    "claude-ask": "ask",
    "gemini-ask": "ask",
    "antigravity-chat": "ask",
    "bash": "ask",
    "edit": "ask",
    "external_directory": "ask"
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "codex_*": "ask",
        "claude-ask": "ask",
        "gemini-ask": "ask",
        "antigravity-chat": "ask"
      }
    },
    "build": {
      "permission": {
        "codex_*": "ask",
        "claude-ask": "ask",
        "gemini-ask": "ask",
        "antigravity-chat": "ask"
      }
    }
  }
}
