#!/usr/bin/env sh
# Cross-platform run launcher — POSIX shim. All logic lives in run.py.
here=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
if command -v python3 >/dev/null 2>&1; then
  PY=python3
elif command -v python >/dev/null 2>&1; then
  PY=python
else
  echo "run: Python 3 is required but was not found on PATH" >&2
  exit 1
fi
exec "$PY" "$here/run.py" "$@"
