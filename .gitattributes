# The POSIX run shim and the launcher must stay LF — they are copied verbatim
# into new projects, and CRLF breaks `#!/usr/bin/env sh` on Linux/macOS.
global/project-templates/run/run    text eol=lf
global/project-templates/run/run.py text eol=lf

# Plugin manifests are committed with the {{LOGGED_IN_EMAIL}} placeholder;
# the inject-email filter (setup/tools/email-filter.py) swaps in the
# logged-in account email on checkout and strips it again on commit.
.claude-plugin/marketplace.json   filter=inject-email
global/.claude-plugin/plugin.json filter=inject-email
