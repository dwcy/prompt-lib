# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.env
.env.*
!.env.example
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*

# uv
# uv.lock SHOULD be committed; nothing to ignore here

# Build / dist
dist/
build/
# Exception: the setup/build/ tree holds the PyInstaller driver, .spec, README,
# and build.cmd — those ARE source and must ship. Only the PyInstaller output
# directories (dist/, intermediate build/) inside setup/build/ stay ignored.
!setup/build/
setup/build/dist/
setup/build/build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Obsidian local workspace state
.obsidian/workspace.json

# OS
.DS_Store
Thumbs.db

# Local-only Claude state (project skills/commands ARE committed; only ephemera here)
.claude/settings.local.json
.claude/worktrees/

# Spec-kit local install state (declared config in .specify/extensions.yml IS committed)
.specify/extensions/.registry

# Generated OKF catalog — regenerate on demand with `python -m cabal.okf export`.
# The hand-written docs/okf/README.md stays tracked; only the generated bundle is ignored.
docs/okf/prompt-lib/

.cabal/

.mcp.json
